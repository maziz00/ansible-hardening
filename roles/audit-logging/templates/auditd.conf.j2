# Managed by Ansible — CIS Hardening
# {{ ansible_managed }}

log_file = /var/log/audit/audit.log
log_format = RAW
log_group = root
max_log_file = {{ cis_auditd_max_log_file }}
max_log_file_action = {{ cis_auditd_max_log_file_action }}
num_logs = 5
space_left = 75
space_left_action = {{ cis_auditd_space_left_action }}
admin_space_left_action = {{ cis_auditd_admin_space_left_action }}
action_mail_acct = {{ cis_auditd_action_mail_acct }}
disk_full_action = halt
disk_error_action = halt
flush = INCREMENTAL_ASYNC
freq = 50
name_format = hostname
